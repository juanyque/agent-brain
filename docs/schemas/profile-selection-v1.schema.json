{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/juanyque/agent-brain/main/docs/schemas/profile-selection-v1.schema.json",
  "title": "agent-brain profile selection v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "default_profile", "project_rules"],
  "properties": {
    "$schema": {"type": "string"},
    "schema_version": {"const": 1},
    "default_profile": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"},
    "project_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path_prefix", "profile"],
        "properties": {
          "path_prefix": {"type": "string", "minLength": 1},
          "profile": {"type": "string", "pattern": "^[a-z][a-z0-9-]*$"}
        }
      }
    }
  }
}
